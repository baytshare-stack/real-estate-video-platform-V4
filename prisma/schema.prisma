generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  username      String?   @unique
  fullName      String    @default("User")
  name          String?
  /// Unique login identifier (admin login uses this + passwordHash)
  email         String    @unique
  emailVerified DateTime?
  /// Bcrypt hash of password (never store plaintext). Admin auth uses this field.
  passwordHash  String?
  image         String?
  country       String?
  city          String?
  /// Discovery: featured agents/agencies sort first
  isFeatured    Boolean   @default(false)
  /// Discovery: “verified only” filter + trust badge
  isVerified    Boolean   @default(false)
  /// Average rating (0–5), optional
  rating        Float?
  phoneCode     String?
  phoneNumber   String?
  phone         String?
  whatsapp      String?
  fullPhoneNumber String?
  phoneVerified Boolean   @default(true)
  otpCode       String?
  otpExpiresAt  DateTime?
  phoneLoginToken           String?
  phoneLoginTokenExpiresAt  DateTime?
  /// Platform roles; admin panel requires Role.ADMIN (see admin JWT + /api/admin/auth)
  role          Role      @default(USER)
  isBlocked     Boolean   @default(false)
  crmStatus     CrmStatus @default(LEAD)
  crmNotes      String?
  createdAt     DateTime  @default(now())
  /// Agent → agency company user (role AGENCY)
  employerId    String?
  employer      User?     @relation("AgencyEmployer", fields: [employerId], references: [id], onDelete: SetNull)
  agencyAgents  User[]    @relation("AgencyEmployer")
  channel       Channel?
  comments          Comment[]
  videoReactions    VideoReaction[]
  commentReactions  CommentReaction[]
  subscriptions     Subscription[]
  accounts          Account[]
  profile           Profile?
  videoShares       VideoShare[]
  crmEvents         CrmEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Profile {
  id           String  @id @default(cuid())
  userId       String  @unique
  name         String?
  bio          String?
  location     String?
  avatar       String?
  facebook     String?
  instagram    String?
  linkedin     String?
  website      String?
  contactEmail String?
  contactPhone String?
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Channel {
  id          String  @id @default(cuid())
  name        String
  description String?
  avatar      String?
  profileImage String?
  bannerImage  String?
  banner        String?
  country       String?
  phone         String?
  whatsapp      String?
  whatsappUrl   String?
  facebookUrl   String?
  instagramUrl  String?
  telegramUrl   String?
  youtubeUrl    String?
  websiteUrl    String?
  subscribersCount Int @default(0)
  ownerId     String  @unique
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  videos      Video[]
  playlists   Playlist[]
  subscriptions Subscription[]
}

model Subscription {
  id String @id @default(cuid())

  subscriberId String
  channelId String

  subscriber User @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([subscriberId, channelId])
}

model Video {
  id          String    @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  thumbnail   String?
  isDemo      Boolean   @default(false)
  channelId   String
  likesCount  Int       @default(0)
  dislikesCount Int     @default(0)
  sharesCount Int       @default(0)
  commentsCount Int     @default(0)
  viewsCount  Int       @default(0)
  isShort     Boolean   @default(false)
  moderationStatus ModerationStatus @default(PENDING)
  /// Denormalized field used for auto-generated property playlists.
  /// Optional for backwards compatibility with older videos.
  propertyType VideoPropertyType?
  createdAt   DateTime  @default(now())
  comments    Comment[]
  videoReactions VideoReaction[]
  shares      VideoShare[]
  property    Property?
  adPlacements AdPlacement[]
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model AdCampaign {
  id          String   @id @default(cuid())
  name        String
  status      AdCampaignStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  creatives   AdCreative[]
  placements  AdPlacement[]
}

model AdCreative {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type        AdCreativeType
  mediaUrl    String
  clickUrl    String?
  createdAt   DateTime @default(now())
  impressions Int       @default(0)
  clicks      Int       @default(0)
}

model AdPlacement {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  videoId     String
  video       Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([campaignId, videoId])
}

model Property {
  id           String         @id @default(cuid())
  videoId      String         @unique
  propertyType PropertyType
  status       PropertyStatus
  price        Decimal?
  currency     String         @default("USD")
  bedrooms     Int?
  bathrooms    Float?
  sizeSqm      Float?
  country      String
  city         String
  address      String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime       @default(now())
  video        Video          @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Comment {
  id              String   @id @default(cuid())
  content         String
  userId          String
  videoId         String
  parentCommentId String?
  likesCount      Int      @default(0)
  dislikesCount   Int      @default(0)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video           Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  parent          Comment? @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[] @relation("CommentReplies")
  reactions       CommentReaction[]

  @@index([videoId])
  @@index([parentCommentId])
}

/// One reaction per user per video (LIKE or DISLIKE)
model VideoReaction {
  id        String       @id @default(cuid())
  userId    String
  videoId   String
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@map("VideoReaction")
}

model CommentReaction {
  id        String       @id @default(cuid())
  userId    String
  commentId String
  type      ReactionType
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model VideoShare {
  id        String   @id @default(cuid())
  userId    String?
  videoId   String
  platform  String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model Playlist {
  id        String   @id @default(cuid())
  name      String
  channelId String
  createdAt DateTime @default(now())

  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
}

model CrmEvent {
  id        String   @id @default(cuid())
  type      String
  userId    String?
  videoId   String?
  channelId String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([videoId])
}

/// Includes real-estate-specific roles; admin authentication uses ADMIN only (separate from NextAuth).
enum Role {
  USER
  AGENT
  AGENCY
  ADMIN
  SUPER_ADMIN
}

enum PropertyType {
  APARTMENT
  VILLA
  LAND
  OFFICE
  SHOP
  HOUSE
  COMMERCIAL
}

enum PropertyStatus {
  FOR_SALE
  FOR_RENT
}

enum CrmStatus {
  LEAD
  ACTIVE
  INACTIVE
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReactionType {
  LIKE
  DISLIKE
}

/// Property categories used to auto-generate playlists on channel pages.
enum VideoPropertyType {
  APARTMENT
  VILLA
  TOWNHOUSE
  STUDIO
  DUPLEX
  LAND
  OTHER
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum AdCreativeType {
  IMAGE
  VIDEO
}
