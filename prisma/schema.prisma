generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  fullName      String
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  country       String?
  phoneCode     String?
  phoneNumber   String?
  role          Role      @default(USER)
  isBlocked     Boolean   @default(false)
  crmStatus     CrmStatus @default(LEAD)
  crmNotes      String?
  createdAt     DateTime  @default(now())
  channel       Channel?
  comments      Comment[]
  likes         Like[]
}

model Channel {
  id          String  @id @default(cuid())
  name        String
  description String?
  avatar      String?
  subscribersCount Int @default(0)
  ownerId     String  @unique
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  videos      Video[]
}

model Video {
  id          String    @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  thumbnail   String?
  channelId   String
  likesCount  Int       @default(0)
  viewsCount  Int       @default(0)
  isShort     Boolean   @default(false)
  moderationStatus ModerationStatus @default(PENDING)
  createdAt   DateTime  @default(now())
  comments    Comment[]
  likes       Like[]
  property    Property?
  adPlacements AdPlacement[]
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model AdCampaign {
  id          String   @id @default(cuid())
  name        String
  status      AdCampaignStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  creatives   AdCreative[]
  placements  AdPlacement[]
}

model AdCreative {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type        AdCreativeType
  mediaUrl    String
  clickUrl    String?
  createdAt   DateTime @default(now())
  impressions Int      @default(0)
  clicks      Int      @default(0)
}

model AdPlacement {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  videoId     String
  video       Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([campaignId, videoId])
}

model Property {
  id           String         @id @default(cuid())
  videoId      String         @unique
  propertyType PropertyType
  status       PropertyStatus
  price        Decimal?
  bedrooms     Int?
  bathrooms    Float?
  sizeSqm      Float?
  country      String
  city         String
  address      String?
  createdAt    DateTime       @default(now())
  video        Video          @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
}

enum Role {
  USER
  AGENT
  AGENCY
  ADMIN
}

enum PropertyType {
  APARTMENT
  VILLA
  LAND
  OFFICE
  SHOP
  HOUSE
  COMMERCIAL
}

enum PropertyStatus {
  FOR_SALE
  FOR_RENT
}

enum CrmStatus {
  LEAD
  ACTIVE
  INACTIVE
}

// CRM fields are stored on the User for now to keep the admin system simple.
// Contact history is still mocked in the UI as requested.

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum AdCreativeType {
  IMAGE
  VIDEO
}
