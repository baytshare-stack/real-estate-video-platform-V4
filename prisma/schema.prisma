generator client {
  provider = "prisma-client-js"
  /// Outside node_modules/.prisma to avoid Windows EPERM when renaming query_engine (AV / locked DLL).
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  /// Pooled URL (Neon `?pgbouncer=true` / `-pooler` host) for the app at runtime.
  url       = env("DATABASE_URL")
  /// Direct (non-pooler) URL for `prisma migrate` — advisory locks fail on transaction poolers (Vercel build P1002).
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  username      String?   @unique
  fullName      String    @default("User")
  name          String?
  /// Unique login identifier (admin login uses this + passwordHash)
  email         String    @unique
  emailVerified DateTime?
  /// Bcrypt hash of password (never store plaintext). Admin auth uses this field.
  passwordHash  String?
  image         String?
  country       String?
  city          String?
  /// Discovery: featured agents/agencies sort first
  isFeatured    Boolean   @default(false)
  /// Discovery: “verified only” filter + trust badge
  isVerified    Boolean   @default(false)
  /// Average rating (0–5), optional
  rating        Float?
  phoneCode     String?
  phoneNumber   String?
  phone         String?
  whatsapp      String?
  fullPhoneNumber String?
  phoneVerified Boolean   @default(true)
  otpCode       String?
  otpExpiresAt  DateTime?
  phoneLoginToken           String?
  phoneLoginTokenExpiresAt  DateTime?
  /// Platform roles; admin panel requires Role.ADMIN (see admin JWT + /api/admin/auth)
  role          Role      @default(USER)
  isBlocked     Boolean   @default(false)
  crmStatus     CrmStatus @default(LEAD)
  crmNotes      String?
  createdAt     DateTime  @default(now())
  /// Agent → agency company user (role AGENCY)
  employerId    String?
  employer      User?     @relation("AgencyEmployer", fields: [employerId], references: [id], onDelete: SetNull)
  agencyAgents  User[]    @relation("AgencyEmployer")
  channel       Channel?
  comments          Comment[]
  videoReactions    VideoReaction[]
  commentReactions  CommentReaction[]
  subscriptions     Subscription[]
  accounts          Account[]
  profile           Profile?
  videoShares       VideoShare[]
  crmEvents         CrmEvent[]
  sentMessages      Message[] @relation("SentMessages")
  receivedMessages  Message[] @relation("ReceivedMessages")
  notifications     Notification[]
  visitBookingsVisitor VisitBooking[] @relation("VisitBookingsVisitor")
  visitBookingsAgent   VisitBooking[] @relation("VisitBookingsAgent")
  contentReports       ContentReport[]
  finalPriceLeadsOwned FinalPriceLead[] @relation("FinalPriceLeadAgent")
  finalPriceLeadsSent  FinalPriceLead[] @relation("FinalPriceLeadVisitor")
  advertiserProfile    AdvertiserProfile?
  submittedAdLeads     Lead[] @relation("AdLeadSubmitter")
  assignedAdLeads      Lead[] @relation("AdLeadAgent")
  adsWallet            Wallet?
  adsWalletTransactions WalletTransaction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Profile {
  id           String  @id @default(cuid())
  userId       String  @unique
  name         String?
  bio          String?
  /// When true, account email may be shown on the public profile (if you add a public view).
  showEmailOnProfile Boolean @default(false)
  location     String?
  avatar       String?
  facebook     String?
  instagram    String?
  linkedin     String?
  website      String?
  contactEmail String?
  contactPhone String?
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  /// Deep link, e.g. /watch/{videoId}
  linkUrl   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

model Channel {
  id          String  @id @default(cuid())
  name        String
  description String?
  avatar      String?
  profileImage String?
  bannerImage  String?
  banner        String?
  country       String?
  phone         String?
  whatsapp      String?
  whatsappUrl   String?
  facebookUrl   String?
  instagramUrl  String?
  telegramUrl   String?
  youtubeUrl    String?
  websiteUrl    String?
  subscribersCount Int @default(0)
  ownerId     String  @unique
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  videos      Video[]
  playlists   Playlist[]
  subscriptions Subscription[]
}

enum SubscriptionNotifyPreference {
  ALL
  PERSONALIZED
  NONE
}

model Subscription {
  id String @id @default(cuid())

  subscriberId String
  channelId String

  subscriber User @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  /// YouTube-style: which new-video notifications this subscriber wants.
  notificationPreference SubscriptionNotifyPreference @default(ALL)

  @@unique([subscriberId, channelId])
}

/// Data-driven motion templates (short / long). Referenced by Video.templateId when isTemplate is true.
model Template {
  id           String   @id @default(cuid())
  name         String
  /// "short" | "long"
  type         String
  previewImage String
  previewVideo String?
  config       Json
  defaultAudio String?
  createdAt    DateTime @default(now())
  videos       Video[]

  @@index([type])
  @@map("Template")
}

model Video {
  id          String    @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  thumbnail   String?
  isDemo      Boolean   @default(false)
  channelId   String
  likesCount  Int       @default(0)
  dislikesCount Int     @default(0)
  sharesCount Int       @default(0)
  commentsCount Int     @default(0)
  viewsCount  Int       @default(0)
  isShort     Boolean   @default(false)
  moderationStatus ModerationStatus @default(PENDING)
  /// Denormalized field used for auto-generated property playlists.
  /// Optional for backwards compatibility with older videos.
  propertyType VideoPropertyType?
  /// Template-based listing (no traditional video file required).
  isTemplate Boolean @default(false)
  templateId String?
  /// Uploaded template frame URLs (ordered).
  images     String[] @default([])
  /// User-uploaded music URL; falls back to Template.defaultAudio when null.
  audio      String?
  createdAt  DateTime @default(now())
  comments    Comment[]
  videoReactions VideoReaction[]
  shares      VideoShare[]
  property    Property?
  visitBookings VisitBooking[]
  /// Denormalized listing category for smart ads (e.g. APARTMENT). Falls back to `propertyType` when null.
  category      String?
  /// Denormalized location label for smart ads (e.g. "Dubai, UAE"). Falls back to property city/country when null.
  location      String?
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  finalPriceLeads FinalPriceLead[]
  adLeads Lead[]

  @@index([channelId, moderationStatus])
  @@index([channelId, isShort])
  @@index([channelId, propertyType])
  @@index([isTemplate])
}

model AdvertiserProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String
  isVerified   Boolean  @default(false)
  /// Kept in sync with `Wallet.balance` for legacy reads; wallet is the billing source of truth.
  balance      Decimal  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  campaigns    Campaign[]
}

enum WalletTransactionType {
  RECHARGE
  IMPRESSION
  CLICK
  LEAD
  /// Funds moved from wallet into a campaign budget at creation (wallet ↓, campaign.budget set).
  CAMPAIGN_ALLOC
}

model Wallet {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance    Decimal  @default(0)
  totalSpent Decimal  @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WalletTransaction {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      WalletTransactionType
  amount    Decimal
  adId      String?
  createdAt DateTime              @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model Campaign {
  id            String          @id @default(cuid())
  advertiserId  String
  advertiser    AdvertiserProfile @relation(fields: [advertiserId], references: [id], onDelete: Cascade)
  name          String
  budget        Decimal
  dailyBudget   Decimal
  spent         Decimal         @default(0)
  status        CampaignStatus  @default(DRAFT)
  startDate     DateTime
  endDate       DateTime
  bidWeight     Float           @default(1.0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  ads           Ad[]

  @@index([advertiserId, status])
  @@index([status, startDate, endDate])
}

model Ad {
  id          String      @id @default(cuid())
  campaignId  String
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type        AdType
  videoUrl    String?
  imageUrl    String?
  thumbnail   String?
  duration    Int         @default(15)
  skipAfter   Int         @default(5)
  ctaType     AdCtaType   @default(WHATSAPP)
  ctaLabel    String?
  ctaUrl      String?
  status      AdStatus    @default(DRAFT)
  placement   AdPlacement @default(PRE_ROLL)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  targeting   Targeting?
  performance AdPerformance?
  leads       Lead[]
  viewerDayImpressions AdViewerDayImpression[]

  @@index([campaignId, status, placement])
}

/// Per-viewer frequency cap for ad delivery (UTC calendar day). Not campaign spend.
model AdViewerDayImpression {
  id        String   @id @default(cuid())
  viewerKey String
  adId      String
  /// UTC date key YYYY-MM-DD for daily reset
  dayUtc    String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([viewerKey, adId, dayUtc])
  @@index([viewerKey, dayUtc])
}

model Targeting {
  id            String   @id @default(cuid())
  adId          String   @unique
  ad            Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  /// Required for delivery: all three must be non-empty and match the listing (strict mode).
  country       String   @default("")
  city          String   @default("")
  area          String   @default("")
  propertyTypes String[]
  priceMin      Decimal?
  priceMax      Decimal?
  userIntent    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdPerformance {
  id          String   @id @default(cuid())
  adId        String   @unique
  ad          Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)
  impressions Int      @default(0)
  views       Int      @default(0)
  clicks      Int      @default(0)
  leads       Int      @default(0)
  watchTime   Int      @default(0)
  spend       Decimal  @default(0)
  updatedAt   DateTime @updatedAt
}

model Lead {
  id        String     @id @default(cuid())
  adId      String
  ad        Ad         @relation(fields: [adId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?      @relation("AdLeadSubmitter", fields: [userId], references: [id], onDelete: SetNull)
  videoId   String
  video     Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)
  agentId   String
  agent     User       @relation("AdLeadAgent", fields: [agentId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  source    LeadSource
  createdAt DateTime   @default(now())

  @@index([adId, createdAt(sort: Desc)])
  @@index([videoId])
  @@index([agentId, createdAt(sort: Desc)])
}

model Property {
  id           String         @id @default(cuid())
  videoId      String         @unique
  propertyType PropertyType
  status       PropertyStatus
  price        Decimal?
  currency     String         @default("USD")
  bedrooms     Int?
  bathrooms    Float?
  sizeSqm      Float?
  country      String
  city         String
  /// Neighborhood / compound (e.g. Hadayek Al Ahram); used for ad targeting when set.
  area         String?
  address      String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime       @default(now())
  video        Video          @relation(fields: [videoId], references: [id], onDelete: Cascade)
  visitBookings VisitBooking[]
}

/// Threading: `parentCommentId` is the parent comment (null = top-level thread). JSON APIs may also accept `parentId` as an alias.
model Comment {
  id              String   @id @default(cuid())
  content         String
  userId          String
  videoId         String
  parentCommentId String?
  likesCount      Int      @default(0)
  dislikesCount   Int      @default(0)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video           Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  parent          Comment? @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         Comment[] @relation("CommentReplies")
  reactions       CommentReaction[]

  @@index([videoId])
  @@index([parentCommentId])
}

/// One reaction per user per video (LIKE or DISLIKE)
model VideoReaction {
  id        String       @id @default(cuid())
  userId    String
  videoId   String
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video        @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@map("VideoReaction")
}

model CommentReaction {
  id        String       @id @default(cuid())
  userId    String
  commentId String
  type      ReactionType
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model VideoShare {
  id        String   @id @default(cuid())
  userId    String?
  videoId   String
  platform  String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model Playlist {
  id        String   @id @default(cuid())
  name      String
  channelId String
  createdAt DateTime @default(now())

  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
}

model CrmEvent {
  id        String   @id @default(cuid())
  type      String
  userId    String?
  videoId   String?
  channelId String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([videoId])
  @@index([channelId])
}

/// Includes real-estate-specific roles; admin authentication uses ADMIN only (separate from NextAuth).
enum Role {
  USER
  AGENT
  AGENCY
  ADMIN
  SUPER_ADMIN
}

enum PropertyType {
  APARTMENT
  VILLA
  LAND
  OFFICE
  SHOP
  HOUSE
  COMMERCIAL
}

enum PropertyStatus {
  FOR_SALE
  FOR_RENT
}

enum CrmStatus {
  LEAD
  ACTIVE
  INACTIVE
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReactionType {
  LIKE
  DISLIKE
}

/// Property categories used to auto-generate playlists on channel pages.
enum VideoPropertyType {
  APARTMENT
  VILLA
  TOWNHOUSE
  STUDIO
  DUPLEX
  LAND
  OTHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
  DELETED
}

enum AdType {
  VIDEO
  IMAGE
}

enum AdStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
  DELETED
}

enum AdPlacement {
  PRE_ROLL
  MID_ROLL
}

enum AdCtaType {
  CALL
  WHATSAPP
  BOOK_VISIT
}

enum LeadSource {
  AD
  VIDEO
}

enum VisitBookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  RESCHEDULED
}



/// Visitor requested the "final price" for a listing; notifies the listing owner and appears in Studio CRM.
model FinalPriceLead {
  id               String   @id @default(cuid())
  videoId          String
  video            Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  agentUserId      String
  agent            User     @relation("FinalPriceLeadAgent", fields: [agentUserId], references: [id], onDelete: Cascade)
  visitorName      String
  visitorPhone     String
  specifications   String   @db.Text
  listedPriceLabel String
  visitorUserId    String?
  visitorUser      User?    @relation("FinalPriceLeadVisitor", fields: [visitorUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([agentUserId, createdAt(sort: Desc)])
  @@index([videoId])
}


enum ContentReportTarget {
  VIDEO
  COMMENT
}

enum ContentReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model ContentReport {
  id             String               @id @default(cuid())
  targetType     ContentReportTarget
  targetId       String
  reporterUserId String?
  reporter       User?                @relation(fields: [reporterUserId], references: [id], onDelete: SetNull)
  reason         String?              @db.Text
  status         ContentReportStatus  @default(PENDING)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([targetType, targetId])
}

/// Scheduled property visit request from a signed-in visitor to a listing (video) owner.
model VisitBooking {
  id            String             @id @default(cuid())
  videoId       String
  propertyId    String?
  visitorUserId String
  agentUserId   String
  visitorName   String
  visitorPhone  String
  visitorEmail  String?
  scheduledAt   DateTime
  message          String?            @db.Text
  responseMessage  String?            @db.Text
  status           VisitBookingStatus @default(PENDING)
  /// Slot before the agent’s latest proposed time (visitor can revert here).
  reschedulePendingFrom          DateTime?
  /// Status to restore if the visitor rejects the agent’s proposed time.
  statusBeforePendingReschedule  VisitBookingStatus?
  /// Visitor-proposed alternative time while awaiting the agent.
  visitorCounterProposalAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  video    Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  visitor  User      @relation("VisitBookingsVisitor", fields: [visitorUserId], references: [id], onDelete: Cascade)
  agent    User      @relation("VisitBookingsAgent", fields: [agentUserId], references: [id], onDelete: Cascade)

  @@index([agentUserId, status, scheduledAt])
  @@index([visitorUserId, updatedAt(sort: Desc)])
  @@index([videoId])
  @@index([agentUserId, updatedAt(sort: Desc)])
}

/// Admin-managed property categories for upload forms; maps to legacy PropertyType / VideoPropertyType enums.
model ListingPropertyType {
  id          String            @id @default(cuid())
  slug        String            @unique
  labelAr     String
  labelEn     String
  mapProperty PropertyType
  mapVideo    VideoPropertyType
  sortOrder   Int               @default(0)
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())

  @@map("ListingPropertyType")
}

/// Admin-managed countries for upload forms (stored keys match Property.country strings).
model ListingCountry {
  id           String               @id @default(cuid())
  key          String               @unique
  labelAr      String
  labelEn      String
  currency     String               @default("USD")
  areaUnit     String               @default("sqm")
  sortOrder    Int                  @default(0)
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  governorates ListingGovernorate[]

  @@map("ListingCountry")
}

/// Governorates / cities within a country (Property.city stores `key`).
model ListingGovernorate {
  id        String         @id @default(cuid())
  countryId String
  country   ListingCountry @relation(fields: [countryId], references: [id], onDelete: Cascade)
  key       String
  labelAr   String
  labelEn   String
  sortOrder Int            @default(0)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@unique([countryId, key])
  @@map("ListingGovernorate")
}

/// Singleton row id = "site" — public theme + layout for the marketing app (`[locale]` routes).
model SiteAppearance {
  id             String   @id
  updatedAt      DateTime @updatedAt
  primaryHex     String   @default("#3b82f6")
  accentHex      String   @default("#6366f1")
  backgroundHex  String   @default("#0f0f0f")
  surfaceHex     String   @default("#121212")
  textHex        String   @default("#f1f1f1")
  mutedHex       String   @default("#a1a1aa")
  borderHex      String   @default("rgba(255,255,255,0.1)")
  fontBodyKey    String   @default("inter")
  fontHeadingKey String   @default("inter")
  baseFontPx     Int      @default(16)
  headingScale   Float    @default(1.06)
  logoUrl        String?
  /// { sidebarDesktop, sidebarMobile, headerRight, homeSections } string[]
  layoutJson     Json?
  /// discover / profile / videoCard UI toggles & layout variants
  uiConfigJson   Json?
}
