# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/real_estate_tv?schema=public"

# NextAuth — set to your public site URL (OAuth redirect / callbacks)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-string"

# Admin JWT (httpOnly cookie sessions). Falls back to NEXTAUTH_SECRET if unset.
ADMIN_JWT_SECRET=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth (optional) — supports FACEBOOK_APP_ID / FACEBOOK_APP_SECRET aliases
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
# FACEBOOK_APP_ID=""
# FACEBOOK_APP_SECRET=""

# Email OTP (Resend) — required in production for /api/auth/register and /api/auth/otp/send
# In development, OTPs are logged if RESEND_API_KEY is unset; API may also return `otp` in JSON.
RESEND_API_KEY=""
# Verified sender, e.g. "RealEstateTV <onboarding@yourdomain.com>"
RESEND_FROM_EMAIL=""

# Cloudinary — direct browser upload (unsigned preset). Required for upload page on Vercel.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# Cloudinary — server-side (optional; signed uploads / admin)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Legacy: SMS/WhatsApp OTP webhook (optional; email OTP is primary now)
OTP_DELIVERY_WEBHOOK_URL=""
OTP_USE_WHATSAPP_DELIVERY="false"
