# Public site origin for canonical URLs, hreflang, sitemap, and Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Database — pooled / app traffic (Neon: often includes `-pooler` in the host)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/real_estate_tv?schema=public"
# Direct connection for Prisma migrations only (Neon: "Direct" in dashboard — host WITHOUT `-pooler`).
# Optional locally if DATABASE_URL is set: `npm run migrate:deploy` / `npm run prisma:generate` copy DATABASE_URL → DIRECT_URL.
# Or set explicitly (same as DATABASE_URL when not using a pooler).
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/real_estate_tv?schema=public"

# NextAuth — set to your public site URL (OAuth redirect / callbacks)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-string"

# Admin JWT (httpOnly cookie sessions). Falls back to NEXTAUTH_SECRET if unset.
ADMIN_JWT_SECRET=""

# Bootstrap admin (POST /api/seed-admin). Required in production: set SEED_ADMIN_TOKEN and call with header x-seed-admin-token.
# You can set email/password here, or send JSON body { "email", "password", "name?" } when the token matches.
SEED_ADMIN_TOKEN=""
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_DISPLAY_NAME=""

# CLI: npm run seed:admin — creates/updates ADMIN (same bcrypt as register)
CREATE_ADMIN_EMAIL=""
CREATE_ADMIN_PASSWORD=""
CREATE_ADMIN_NAME=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth (optional) — supports FACEBOOK_APP_ID / FACEBOOK_APP_SECRET aliases
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
# FACEBOOK_APP_ID=""
# FACEBOOK_APP_SECRET=""

# --- Transactional email (production on Vercel: set Resend here) ---
# Preferred: Resend (https://resend.com). Verify your domain, then use an address on that domain.
RESEND_API_KEY=""
# Example: "RealEstateTV <noreply@yourdomain.com>" — must be allowed in Resend dashboard
RESEND_FROM_EMAIL=""
# If you omit RESEND_FROM_EMAIL, EMAIL_FROM is used as the Resend "from" address (must still be verified in Resend).
# EMAIL_FROM="noreply@yourdomain.com"

# Optional: skip real email on private demos only (NEVER on public production)
# ALLOW_UNCONFIGURED_EMAIL="true"

# SMTP fallback (only if RESEND_API_KEY is unset)
# EMAIL_SERVER='{"host":"smtp.example.com","port":587,"auth":{"user":"...","pass":"..."}}'
# EMAIL_FROM=""
# EMAIL_PASSWORD=""
# SMTP_HOST=""
# SMTP_PORT="587"

# Cloudinary — direct browser upload (unsigned preset). Required for upload page on Vercel.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""

# Cloudinary — server-side (optional; signed uploads / admin)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Legacy: SMS/WhatsApp OTP webhook (optional; email OTP is primary now)
OTP_DELIVERY_WEBHOOK_URL=""
OTP_USE_WHATSAPP_DELIVERY="false"
